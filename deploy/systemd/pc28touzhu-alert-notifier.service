[Unit]
Description=pc28touzhu Platform Alert Notifier (Telegram Bot)
After=network.target pc28touzhu-platform.service

[Service]
Type=simple
WorkingDirectory=/www/wwwroot/pc28touzhu
Environment=PYTHONPATH=src
EnvironmentFile=/www/wwwroot/pc28touzhu/.env
Environment=ALERT_TELEGRAM_ENABLED=true
ExecStart=/usr/bin/env ALERT_NOTIFIER_ONCE=false python3 platform_alert_notifier.py
Restart=always
RestartSec=5
User=www
Group=www

[Install]
WantedBy=multi-user.target
