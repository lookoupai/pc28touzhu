[Unit]
Description=pc28touzhu Telegram Daily Ranking Reporter
After=network.target pc28touzhu-platform.service

[Service]
Type=simple
WorkingDirectory=/www/wwwroot/pc28touzhu
EnvironmentFile=/www/wwwroot/pc28touzhu/.env
Environment=TG_REPORT_ENABLED=true
ExecStart=/usr/bin/env TG_REPORT_ONCE=false /www/wwwroot/pc28touzhu/deploy/systemd/pc28-python.sh telegram_daily_reporter.py
Restart=always
RestartSec=5
User=www
Group=www

[Install]
WantedBy=multi-user.target
